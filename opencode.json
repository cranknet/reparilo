{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "superpowers@git+https://github.com/obra/superpowers.git"
  ],
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest"
      ],
      "enabled": false
    },
    "shadcn": {
      "type": "local",
      "command": [
        "npx",
        "shadcn@latest",
        "mcp"
      ],
      "enabled": false
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ],
      "enabled": false
    },
    "postgres": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-postgres-server"
      ],
      "environment": {
        "PG_HOST": "localhost",
        "PG_PORT": "5432",
        "PG_USER": "postgres",
        "PG_PASSWORD": "Azer",
        "PG_DATABASE": "Reparilo"
      },
      "enabled": true
    },
    "stitch": {
      "type": "remote",
      "url": "https://stitch.googleapis.com/mcp",
      "headers": {
        "Accept": "application/json",
        "X-Goog-Api-Key": "AQ.Ab8RN6L11EFTITl_X3FRCQd1LFYwBZQz-un8_UXkdds3JbVVDw"
      },
      "enabled": false
    },
    "socraticode": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "socraticode"
      ],
      "enabled": true
    }
  }
}