# ─── Runtime ────────────────────────────────────────────────────────────
# NODE_ENV       — "development" | "test" | "production". Controls: SPA serving,
#                  HSTS/CSP headers, error detail, CSRF cookie security, auth
#                  validation. Defaults to "development". Required in Coolify.
NODE_ENV=development

# PORT           — HTTP port the Fastify server binds to. Default: 4000.
PORT=4000

# HOST           — Bind address. "0.0.0.0" to listen on all interfaces.
HOST=0.0.0.0

# LOG_LEVEL      — "fatal" | "error" | "warn" | "info" | "debug" | "trace".
#                  Production: "info" (or "warn" for less noise).
LOG_LEVEL=info

# TRUST_PROXY    — "true" | "false". Honours X-Forwarded-For when behind a
#                  reverse proxy (Cloudflare → Traefik → Coolify). Defaults to
#                  true in production. Set to "true" explicitly if behind a proxy
#                  in development.
# TRUST_PROXY=true

# ─── Database ──────────────────────────────────────────────────────────
# DATABASE_URL    — PostgreSQL connection string. Used by both Prisma and the
#                   pg driver adapter. Required.
#                   Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://reparilo:reparilo_secret@localhost:5432/reparilo"

# ─── Secrets ──────────────────────────────────────────────────────────
# All three must be ≥32 characters. Never use placeholders like "change-me"
# or "example" — the server refuses to start with them.
# Generate with: node -e "console.log(require('node:crypto').randomBytes(48).toString('base64url'))"

# BETTER_AUTH_SECRET — Signs session tokens. Used by Better Auth.
BETTER_AUTH_SECRET=replace-with-a-real-random-secret-at-least-32-chars

# AI_ENCRYPTION_KEY  — AES-256 key for encrypting the AI provider API key at rest.
AI_ENCRYPTION_KEY=replace-with-a-real-random-key-at-least-32-chars

# COOKIE_SECRET    — Signs the CSRF cookie. Required in production (server
#                    refuses boot without it). In dev, falls back to
#                    BETTER_AUTH_SECRET.
# COOKIE_SECRET=replace-with-another-real-random-secret-at-least-32-chars

# ─── URLs ──────────────────────────────────────────────────────────────
# APP_URL   — The single public origin of the app. Used for: CORS origins,
#             Better Auth baseURL, receipt QR codes, tracking links.
#             Required in production (server refuses boot with localhost).
#             Example: https://reparilo.yourdomain.com
# APP_URL=https://reparilo.yourdomain.com

# API_URL   — Override if the API is on a different host. Defaults to APP_URL.
#             Rarely needed — the same origin serves both.
# API_URL=https://api.reparilo.yourdomain.com

# EXTRA_TRUSTED_ORIGINS — Comma-separated extra origins allowed by CORS.
#                         Needed for: Capacitor Android (capacitor://localhost),
#                         local testing from other devices, etc.
# EXTRA_TRUSTED_ORIGINS=capacitor://localhost,http://192.168.1.100:5173

# ─── Frontend (build-time only) ────────────────────────────────────────
# VITE_API_BASE_URL — Required for Android builds. Tells the Capacitor WebView
#                     where to find the API. Leave empty in dev (Vite proxy
#                     handles it) and in browser production (same-origin works).
#                     For Android: VITE_API_BASE_URL=https://reparilo.shop
VITE_API_BASE_URL=

# ─── Seeding ──────────────────────────────────────────────────────────
# SEED_ADMIN_PASSWORD — Password for the initial admin user created by
#                       `pnpm db:seed`. Defaults to "admin123" if unset.
#                       Always set this in production. The user is forced to
#                       change it on first login.
# SEED_ADMIN_PASSWORD=

# ─── Filesystem ────────────────────────────────────────────────────────
# UPLOAD_DIR — Where job photos, avatars, and other uploads are stored.
#              Default: ./uploads (relative to working directory).
#              In Coolify: mount a persistent volume at this path.
UPLOAD_DIR=./uploads

# ─── Email (optional — password reset disabled if unset) ──────────────
# All five must be set together, or none. If any are missing, the password
# reset email flow is silently disabled.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM="Reparilo <noreply@reparilo.example.com>"

# ─── Timezone (optional) ──────────────────────────────────────────────
# TZ — IANA timezone name (e.g. "Africa/Algiers"). Fallback for the shop
#      timezone setting in the admin panel. If unset, defaults to "UTC".
# TZ=Africa/Algiers