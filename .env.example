DATABASE_URL="postgresql://reparilo:reparilo_secret@localhost:5432/reparilo"
NODE_ENV=development
PORT=4000
HOST=0.0.0.0
BETTER_AUTH_SECRET=change-me-in-production-min-32-chars!!
AI_ENCRYPTION_KEY=change-me-in-production-32-bytes!!
UPLOAD_DIR=./uploads
# Set to "true" to skip auth in development. NEVER use in production.
AUTH_BYPASS=
# Base URL for the API server. Leave empty for web (uses Vite proxy).
# Set for Android: e.g. VITE_API_BASE_URL=https://api.reparilo.com
VITE_API_BASE_URL=
