  "scripts": {
    "dev": "bun run --watch server/index.ts & vite",
    "dev:front": "vite",
    "server": "bun run --watch server/index.ts",
    "start": "bun run server/index.ts",
    "start:prod": "bun run db:migrate-deploy && bun start",
    "build": "bun run db:generate && vite build",
    "build:mobile": "bun run build && cap sync",
    "build:prod": "bun run build",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate-deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:reset": "prisma migrate reset --force && bun run db:seed",
    "db:studio": "prisma studio",
    "db:seed": "bun run prisma/seed.ts",
    "db:seed:prod": "bun run prisma/seed.ts",
    "scan-i18n": "bun run scripts/scan-i18n.ts",
    "sync-locales": "bun run scripts/sync-locales.ts",
    "setup-worktree": "bun run scripts/setup-worktree.ts",
    "android": "cap sync && cap open android",
    "cap:sync": "cap sync",
    "cap:copy": "cap copy",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepare": "husky"
  },
