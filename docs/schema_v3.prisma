// Reparilo — Prisma Schema
// Version: 3.1
// Database: PostgreSQL
// Changes from v3.0: Fix race condition (P1), add missing indexes (P2), make estimatedCost required (P5)
// Changes from v2: See docs/plans/2026-04-12-reparilo-mvp.md — Schema Audit

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  OWNER
  TECHNICIAN
  FRONT_DESK
}

enum JobStatus {
  INTAKE
  WAITING_FOR_PARTS
  IN_REPAIR
  ON_HOLD
  DONE
  DELIVERED
  RETURNED
  CANCELLED
}

enum PartCategory {
  SCREEN
  BATTERY
  CHARGING_PORT
  CAMERA
  SPEAKER
  MICROPHONE
  MOTHERBOARD
  HOUSING
  BUTTON
  OTHER
}

enum RepairCategory {
  HARDWARE
  SOFTWARE
  DIAGNOSTIC
  OTHER
}

enum NotifyChannel {
  WHATSAPP
  SMS
}

enum AuditAction {
  JOB_CREATED
  STATUS_CHANGED
  TECHNICIAN_ASSIGNED
  COST_UPDATED
  PART_ADDED
  PART_REMOVED
  REPAIR_ADDED
  REPAIR_REMOVED
  NOTE_ADDED
  PHOTO_ADDED
  WARRANTY_RETURN_CREATED
  NOTIFICATION_SENT
}

enum AiRole {
  USER
  ASSISTANT
}

// ─────────────────────────────────────────────
// USER
// P4 Note: email is required and unique — used for account
//          identification; auth is username + password via Better Auth.
// ─────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  email     String   @unique
  password  String
  role      Role
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignedJobs   Job[]           @relation("AssignedTechnician")
  createdJobs    Job[]           @relation("CreatedBy")
  updatedJobs    Job[]           @relation("UpdatedBy")
  notes          JobNote[]
  jobParts       JobPart[]
  jobRepairs     JobRepair[]
  auditLogs      AuditLog[]
  chatHistory    AiChatHistory[]

  @@map("users")
}

// ─────────────────────────────────────────────
// CUSTOMER
// ─────────────────────────────────────────────

model Customer {
  id        String   @id @default(cuid())
  name      String
  phone     String   @unique
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jobs      Job[]

  @@map("customers")
}

// ─────────────────────────────────────────────
// DEVICE
// Fix #8: color removed — moved to Job
// ─────────────────────────────────────────────

model Device {
  id        String   @id @default(cuid())
  brand     String
  model     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jobs      Job[]

  @@unique([brand, model])
  @@index([brand])
  @@map("devices")
}

// ─────────────────────────────────────────────
// JOB COUNTER
// Fix #7:  new model for job code generation
// P1 Fix:  Use serializable $transaction when incrementing lastSeq
//          to prevent race conditions on concurrent job creation.
//          The @@unique([year]) constraint provides a safety net.
// ─────────────────────────────────────────────

model JobCounter {
  id      String @id @default(cuid())
  year    Int
  lastSeq Int   @default(0)

  @@unique([year])
  @@map("job_counters")
}

// ─────────────────────────────────────────────
// JOB
// Fix #1:  onDelete/onUpdate on all relations
// Fix #2:  removed redundant @@index([jobCode])
// Fix #3:  added composite indexes
// Fix #8:  color field added (moved from Device)
// Fix #10: finalCost removed — computed on read
// ─────────────────────────────────────────────

model Job {
  id         String    @id @default(cuid())
  jobCode    String    @unique
  accessCode String

  customerId      String
  customer        Customer  @relation(fields: [customerId], references: [id], onDelete: Restrict)

  deviceId        String
  device          Device    @relation(fields: [deviceId], references: [id], onDelete: Restrict)
  color           String?

  reportedProblem String
  conditionNotes  String?
  status          JobStatus @default(INTAKE)

  estimatedCost   Decimal   @db.Decimal(10, 2)
  depositAmount   Decimal?  @db.Decimal(10, 2)

  estimatedDate   DateTime? @db.Date
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  isWarrantyReturn Boolean  @default(false)
  warrantyForJobId String?
  warrantyForJob   Job?     @relation("WarrantyReturn", fields: [warrantyForJobId], references: [id], onDelete: SetNull)
  warrantyReturns  Job[]    @relation("WarrantyReturn")

  createdById     String
  createdBy       User      @relation("CreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedById     String?
  updatedBy       User?     @relation("UpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  technicianId    String?
  technician      User?     @relation("AssignedTechnician", fields: [technicianId], references: [id], onDelete: SetNull)

  photos          JobPhoto[]
  notes           JobNote[]
  partsUsed       JobPart[]
  partsWaiting    JobPartsWaiting[]
  repairs         JobRepair[]
  auditLogs       AuditLog[]

  @@index([customerId])
  @@index([deviceId])
  @@index([status])
  @@index([technicianId])
  @@index([createdById])
  @@index([warrantyForJobId])
  @@index([status, createdAt])
  @@index([status, estimatedDate])
  @@map("jobs")
}

// ─────────────────────────────────────────────
// JOB PHOTOS
// ─────────────────────────────────────────────

model JobPhoto {
  id        String   @id @default(cuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  path      String
  createdAt DateTime @default(now())

  @@index([jobId])
  @@map("job_photos")
}

// ─────────────────────────────────────────────
// JOB NOTES
// ─────────────────────────────────────────────

model JobNote {
  id                String   @id @default(cuid())
  jobId             String
  job               Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  content           String
  isCustomerVisible Boolean  @default(false)
  createdById       String
  createdBy         User     @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdAt         DateTime @default(now())

  @@index([jobId])
  @@map("job_notes")
}

// ─────────────────────────────────────────────
// JOB PARTS WAITING
// ─────────────────────────────────────────────

model JobPartsWaiting {
  id        String   @id @default(cuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  partName  String
  supplier  String?
  createdAt DateTime @default(now())

  @@index([jobId])
  @@map("job_parts_waiting")
}

// ─────────────────────────────────────────────
// PARTS CATALOG
// Fix #3:  added @@index([name])
// Fix #9:  added isActive
// ─────────────────────────────────────────────

model PartsCatalog {
  id           String       @id @default(cuid())
  name         String
  category     PartCategory
  defaultPrice Decimal      @db.Decimal(10, 2)
  supplier     String?
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  jobParts     JobPart[]

  @@index([name])
  @@map("parts_catalog")
}

// ─────────────────────────────────────────────
// JOB PARTS (CONSUMED)
// ─────────────────────────────────────────────

model JobPart {
  id          String        @id @default(cuid())
  jobId       String
  job         Job           @relation(fields: [jobId], references: [id], onDelete: Cascade)

  partId      String?
  part        PartsCatalog? @relation(fields: [partId], references: [id], onDelete: SetNull)

  partName    String
  category    PartCategory
  unitPrice   Decimal       @db.Decimal(10, 2)
  quantity    Int           @default(1)
  supplier    String?
  totalCost   Decimal       @db.Decimal(10, 2)

  createdById String
  createdBy   User          @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdAt   DateTime      @default(now())

  @@index([jobId])
  @@map("job_parts")
}

// ─────────────────────────────────────────────
// REPAIR CATALOG
// Fix #3:  added @@index([name])
// Fix #9:  added isActive
// ─────────────────────────────────────────────

model RepairCatalog {
  id           String         @id @default(cuid())
  name         String
  category     RepairCategory
  defaultPrice Decimal        @db.Decimal(10, 2)
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  jobRepairs   JobRepair[]

  @@index([name])
  @@map("repair_catalog")
}

// ─────────────────────────────────────────────
// JOB REPAIRS (PERFORMED)
// ─────────────────────────────────────────────

model JobRepair {
  id         String          @id @default(cuid())
  jobId      String
  job        Job             @relation(fields: [jobId], references: [id], onDelete: Cascade)

  repairId   String?
  repair     RepairCatalog?  @relation(fields: [repairId], references: [id], onDelete: SetNull)

  repairName String
  category   RepairCategory
  price      Decimal         @db.Decimal(10, 2)

  createdById String
  createdBy   User           @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdAt   DateTime       @default(now())

  @@index([jobId])
  @@map("job_repairs")
}

// ─────────────────────────────────────────────
// AUDIT LOG
// Fix #11: added metadata Json?
// P3 Note: metadata holds structured payload (enums, IDs),
//          fromValue/toValue are human-readable display strings.
// ─────────────────────────────────────────────

model AuditLog {
  id        String      @id @default(cuid())
  jobId     String
  job       Job         @relation(fields: [jobId], references: [id], onDelete: Cascade)
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Restrict)
  action    AuditAction
  fromValue String?
  toValue   String?
  note      String?
  metadata  Json?
  createdAt DateTime    @default(now())

  @@index([jobId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────
// NOTIFICATION TEMPLATES
// Fix #6: added @@unique([name, channel])
// ─────────────────────────────────────────────

model NotificationTemplate {
  id        String        @id @default(cuid())
  name      String
  channel   NotifyChannel
  body      String
  isDefault Boolean       @default(false)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([name, channel])
  @@index([channel])
  @@map("notification_templates")
}

// ─────────────────────────────────────────────
// AI SETTINGS (single row)
// Fix #4: fixed id for single-row upsert
// ─────────────────────────────────────────────

model AiSettings {
  id              String   @id
  endpointUrl     String   @default("")
  apiKeyEncrypted String   @default("")
  model           String?
  temperature     Float    @default(0.7)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("ai_settings")
}

// ─────────────────────────────────────────────
// AI CHAT HISTORY
// Fix #5: added userId FK + composite index
// ─────────────────────────────────────────────

model AiChatHistory {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      AiRole
  content   String
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([createdAt])
  @@map("ai_chat_history")
}

// ─────────────────────────────────────────────
// SHOP SETTINGS (single row)
// Fix #4: fixed id for single-row upsert
// ─────────────────────────────────────────────

model ShopSettings {
  id            String   @id
  shopName      String   @default("")
  logoPath      String?
  address       String?
  phone         String?
  currency      String   @default("DZD")
  receiptFooter String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("shop_settings")
}
